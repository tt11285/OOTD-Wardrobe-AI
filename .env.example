# ── Supabase (data, storage, auth) ──────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers ─────────────────────────────────────────────────────────────
# Set the provider to enable real Claude recognition + outfit styling + chat.
# Leave it unset to run in deterministic demo mode (no keys needed).
OOTD_RECOGNITION_PROVIDER=ofox-anthropic

# Claude via the Ofox Anthropic-compatible proxy (recognition, outfits, chat)
OFOX_API_KEY=
OFOX_ANTHROPIC_MESSAGES_URL=https://api.ofox.ai/anthropic/v1/messages
OOTD_RECOGNITION_MODEL=anthropic/claude-sonnet-4.5
OOTD_RECOMMENDATION_MODEL=anthropic/claude-sonnet-4.5

# Google Gemini — background removal / cutout, full-body look images,
# the Dressy avatar, and RAG embeddings.
GEMINI_API_KEY=
OOTD_IMAGE_EDIT_MODEL=gemini-2.5-flash-image
OOTD_EMBEDDING_MODEL=gemini-embedding-001

# The app runs fully in demo mode without any of the AI keys above —
# recognition and outfits fall back to deterministic sample data.
